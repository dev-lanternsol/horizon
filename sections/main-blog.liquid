<script
  src="{{ 'blog-posts-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
{% liquid
    # Build unique categories list
    assign categories = ''
    for a in blog.articles
      assign cat = a.metafields.custom.category | default: ''
      if cat != ''
        unless categories contains cat
          assign categories = categories | append: cat | append: '|'
        endunless
      endif
    endfor
    assign categories = categories | split: '|'
  %}
<blog-posts-list section-id="{{ section.id }}">
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="
      section
      color-{{ section.settings.color_scheme }}
      blog-posts
      spacing-style
      size-style
    "
    data-testid="blog-posts"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {% content_for 'blocks' %}
 {% liquid
  assign total_count_all =  blog.articles.size
        assign items_on_page = 9
        assign last_page = total_count_all | divided_by: items_on_page
          assign remainder = total_count_all | modulo: items_on_page
          if remainder > 0
            assign last_page = last_page | plus: 1
          endif
      %}
      <div
          class="article-grid__filters"
          role="tablist"
          aria-label="Article categories">
          <button
            class="article-chip article-chip--active"
            data-category=""
            data-total="{{ total_count_all }}">All</button>
         {% for cat in categories %}
            {% if cat != blank %}
              <button
                class="article-chip"
                data-category="{{ cat | escape }}"
               >{{ cat }}</button>
            {% endif %}
          {% endfor %}
        </div>
    <div
      ref="grid"
      class="blog-posts-container"
      data-last-page="{{ last_page }}"
    >
     
      {% for article in blog.articles %}
         {% assign idx0 = forloop.index0 %}
          {% assign page = idx0 | divided_by: items_on_page | plus: 1 %}
           {% assign cat = article.metafields.custom.category | default: '' %}
        {% liquid
          # Defaults for compact layout
          assign col_span = 2
          assign scale = 0.6
   
        %}
        {% style %}
          [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
            --col-span: {{ col_span }};
            --blog-post-card-scale: {{ scale }};
          }

          @media screen and (max-width: 749px) {
            [data-blog-index="{{ section.id }}-{{ forloop.index }}"] {
              --col-span: 6;
              --blog-post-card-scale: 0.5;
            }
          }
        {% endstyle %}
        <div
          class="blog-post-item"
          data-testid="blog-post-item"
          ref="cards[]"
          data-page="{{ page }}"
          data-category="{{ cat | escape }}"
          {% if page > 1 %}
          style="display:none"
          {% endif %}
          data-blog-index="{{ section.id }}-{{ forloop.index }}"
        >
          {% content_for 'block', id: 'static-blog-post-card', type: '_blog-post-card', article: article %}
        </div>
      {% endfor %}
    </div>
    <div class="article-grid__footer">
            <div class="article-grid__count">
              You have viewed
              <span data-count-shown>{{ items_on_page | at_most: total_count_all }}</span>
              of
              <span data-count-total>{{ total_count_all }}</span>
              results
            </div>
            <div class="article-grid__progress">
              <div class="article-grid__progress-bar" style="width: {{ items_on_page | at_most: total_count_all | times: 100.0 | divided_by: total_count_all }}%"></div>
            </div>
            <button class="article-grid__load-more" ref="viewMoreNext">Load More Articles</button>
          </div>
  </div>
</blog-posts-list>
{% javascript %}
  (() => {

// Avoid Liquid in JS: locate the section element relative to this script
    const sectionEl = (() => {
      const script = document.currentScript;
      if (script) {
        const nearest = script.closest('.blog-posts');
        if (nearest) return nearest;
        
      }
      return document.querySelector('.blog-posts');
    })();
    if (! sectionEl) return;
    

    const gridEl = sectionEl.querySelector('[ref="grid"]');
    const countShownEl = sectionEl.querySelector('[data-count-shown]');
    const countTotalEl = sectionEl.querySelector('[data-count-total]');
    const progressEl = sectionEl.querySelector('.article-grid__progress-bar');
    const chips = Array.from(sectionEl.querySelectorAll('.article-chip'));
    const loadMoreBtn = sectionEl.querySelector('[ref="viewMoreNext"]');
    let currentPage = 1;
    const lastPage = Number(gridEl ?. dataset ?. lastPage || gridEl ?. getAttribute('data-last-page') || 1);

 const updateCounts = () => {
  const cards = Array.from(gridEl.querySelectorAll('[ref="cards[]"]'));
  const activeChip = chips.find((c) => c.classList.contains('article-chip--active'));
  const activeCategory = activeChip ? activeChip.dataset.category : '';

  // Total = all cards matching category (not just visible)
  const total = cards.filter((c) => {
    return !activeCategory || c.dataset.category === activeCategory;
  }).length;

  // Visible cards (after pagination + filter)
  const visible = cards.filter((c) => {
    return c.style.display !== 'none' &&
      (!activeCategory || c.dataset.category === activeCategory);
  }).length;

  countShownEl.textContent = String(visible);
  countTotalEl.textContent = String(total);

  const pct = total > 0
    ? Math.min(100, Math.round((visible / total) * 100))
    : 0;

  progressEl.style.width = pct + '%';
};

    const applyFilter = (category) => {
      const cards = Array.from(gridEl.querySelectorAll('[ref="cards[]"]'));
      cards.forEach((card) => {
        const matches = !category || card.dataset.category === category;
        card.style.display = matches
          ? ''
          : 'none';
      });
      updateCounts();
      document.dispatchEvent(new Event('filter:update'));
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('article-chip--active'));
        chip.classList.add('article-chip--active');
        applyFilter(chip.dataset.category || '');
      });
    });

// Update counts when new cards are appended
    const observer = new MutationObserver(() => updateCounts());
    observer.observe(gridEl, {
      childList: true,
      subtree: false
    });

// Client-side progressive reveal
    loadMoreBtn ?. addEventListener('click', () => {
      if (currentPage >= lastPage) return;
      
      currentPage += 1;
      const nextCards = Array.from(gridEl.querySelectorAll('[ref="cards[]"][data-page="' + currentPage + '"]'));
      nextCards.forEach((c) => (c.style.display = ''));
      updateCounts();
      if (currentPage >= lastPage) {
        loadMoreBtn.style.display = 'none';
      }
    });

    updateCounts();
  })();
{% endjavascript %}
{% stylesheet %}
  /**
   * Blog posts page layout
   */
  .blog-posts {
    --page-content-width: var(--narrow-page-width);
    --page-width: calc(var(--page-content-width) + (var(--page-margin) * 2));
    --columns-gap: 36px;
    --rows-gap: 36px;
  }

  .blog-posts-container {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
    width: 100%;
    column-gap: var(--columns-gap);
    row-gap: var(--rows-gap);
  }

  /**
   * Blog post item grid positioning and scaling.
   * Layout is calculated in Liquid based on total article count.
   * Mobile overrides are applied per-item in inline styles for proper specificity.
   */
  .blog-post-item {
    grid-column: span var(--col-span);
  }

  /**
   * When there's no image, the blog post item has a border.
   */
  .blog-post-item {
    border: 1px solid rgb(var(--color-foreground-rgb) / var(--opacity-20));
    padding: 0 1rem 1rem;
  }

  .blog-post-item:has(.blog-post-card__image-container) {
    border: none;
    padding: 0;
  }
{% endstylesheet %}

