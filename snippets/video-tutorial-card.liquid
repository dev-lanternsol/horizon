{%- doc -%}
  Renders a single video tutorial card matching the Figma "Video Card" component.
  Tags act as filter triggers; the play surface opens a YouTube popup.

  @param {object} block - The video block (with thumbnail, duration, tags, title, link)

  @example
  {% render 'video-tutorial-card', block: block %}
{%- enddoc -%}

{%- liquid
  assign thumbnail = block.settings.thumbnail
  assign title = block.settings.title
  assign duration = block.settings.duration
  assign tag_1 = block.settings.tag_1
  assign tag_2 = block.settings.tag_2
  assign youtube_url = block.settings.link
-%}

<article class="vt-card" {{ block.shopify_attributes }}>
  <button
    type="button"
    class="vt-card__media"
    data-vt-play
    data-youtube="{{ youtube_url | escape }}"
    aria-label="{{ 'general.video.play' | t: default: 'Play video' }}: {{ title | escape }}"
  >
    {%- if thumbnail != blank -%}
      {{
        thumbnail
        | image_url: width: 800
        | image_tag:
          widths: '400, 600, 800',
          sizes: '(min-width: 1100px) 384px, (min-width: 750px) 33vw, 50vw',
          alt: title,
          class: 'vt-card__img',
          loading: 'lazy'
      }}
    {%- else -%}
      <span class="vt-card__img vt-card__img--placeholder">
        {{ 'image' | placeholder_svg_tag: 'vt-card__placeholder' }}
      </span>
    {%- endif -%}

    {%- if duration != blank -%}
      <span class="vt-card__duration">{{ duration }}</span>
    {%- endif -%}

    <span class="vt-card__play" aria-hidden="true">
      <svg viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 0V14L11 7L0 0Z" fill="currentColor"/>
      </svg>
    </span>
  </button>

  {%- if tag_1 != blank or tag_2 != blank -%}
    <div class="vt-card__tags">
      {%- if tag_1 != blank -%}
        <button type="button" class="vt-card__tag" data-vt-tag="{{ tag_1 | escape }}">{{ tag_1 }}</button>
      {%- endif -%}
      {%- if tag_2 != blank -%}
        <button type="button" class="vt-card__tag" data-vt-tag="{{ tag_2 | escape }}">{{ tag_2 }}</button>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if title != blank -%}
    <button
      type="button"
      class="vt-card__title-btn"
      data-vt-play
      data-youtube="{{ youtube_url | escape }}"
    >
      <h3 class="vt-card__title">{{ title }}</h3>
    </button>
  {%- endif -%}
</article>

